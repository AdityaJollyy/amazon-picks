# ---- Database (Neon Postgres) ----
# Paste your Neon connection string here.
# IMPORTANT: use the DIRECT (non-pooled) string for now — turn OFF "Connection pooling"
# in the Neon dashboard before copying. Pooled connections break Prisma migrations.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# ---- Server ----
PORT=5000
NODE_ENV=development
